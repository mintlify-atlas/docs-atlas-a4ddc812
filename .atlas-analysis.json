  "keyFeatures": [
    "Visual notebook-style pipeline builder with Python, SQL, and R support",
    "50+ prebuilt data source and destination connectors",
    "Built-in orchestration and scheduling with cron support",
    "Native dbt integration for SQL transformations",
    "Real-time streaming pipelines with Kafka, RabbitMQ, and more",
    "Dynamic block execution for parallel processing",
    "Spark and distributed compute integration",
    "AI-assisted code generation and debugging",
    "Version control and CI/CD integration",
    "Multi-environment deployment (Docker, Kubernetes, cloud platforms)"
  ],
  "publicApiSurface": [
    "mage init - Initialize a new Mage project",
    "mage start - Start the Mage server and UI",
    "mage run - Execute a pipeline programmatically",
    "Pipeline.create() - Create a new pipeline",
    "Pipeline.get() - Retrieve an existing pipeline",
    "Pipeline.execute() - Run a pipeline",
    "Block.create() - Create a new block",
    "Block.execute() - Execute a block",
    "@data_loader - Decorator for data loading blocks",
    "@transformer - Decorator for transformation blocks",
    "@data_exporter - Decorator for data export blocks",
    "@sensor - Decorator for sensor blocks",
    "@custom - Decorator for custom blocks",
    "VariableManager - Manage pipeline variables and state",
    "ExecutorFactory - Create pipeline and block executors",
    "DataIntegration - Run data integration pipelines",
    "REST API endpoints for pipelines, blocks, triggers, and runs"
  ]
}
